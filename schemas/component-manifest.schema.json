{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ziolkowskiw/kraken-ui-kit/schemas/component-manifest.schema.json",
  "title": "Kraken UI Kit component manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "title",
    "description",
    "install",
    "source",
    "figma",
    "exports",
    "variants",
    "props",
    "slots",
    "tokens",
    "a11y",
    "usage",
    "boundaries",
    "whenToUseInstead",
    "aliases",
    "keywords",
    "notes"
  ],
  "properties": {
    "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string" },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "registryItem", "dependencies", "registryDependencies"],
      "properties": {
        "command": { "type": "string", "pattern": "^npx shadcn add @kraken/[a-z0-9-]+$" },
        "registryItem": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "registryDependencies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "source": { "type": "string", "pattern": "^src/components/ui/[a-z0-9-]+\\.tsx$" },
    "story": { "type": "string", "pattern": "^src/components/ui/[a-z0-9-]+\\.stories\\.tsx$" },
    "figma": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["nodeId", "fileKey"],
          "properties": {
            "nodeId": { "type": "string", "pattern": "^\\d+:\\d+$" },
            "fileKey": { "type": "string", "pattern": "^[A-Za-z0-9]+$" }
          }
        }
      ]
    },
    "exports": { "type": "array", "items": { "type": "string" } },
    "variants": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axes"],
      "properties": {
        "axes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["values"],
            "properties": {
              "values": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
              "default": { "type": "string" }
            }
          }
        },
        "compound": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["when"],
            "properties": {
              "when": {
                "type": "object",
                "additionalProperties": { "type": ["string", "boolean", "number"] }
              },
              "note": { "type": "string" }
            }
          }
        }
      }
    },
    "props": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "enum": ["enum", "boolean", "string|node", "mapped"] },
          "values": { "type": "array", "items": { "type": "string" } },
          "default": { "type": "string" },
          "figmaProperty": { "type": "string" },
          "figmaValues": { "type": "string" }
        }
      }
    },
    "slots": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exports", "figmaParts"],
      "properties": {
        "exports": { "type": "array", "items": { "type": "string" } },
        "figmaParts": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$" }
        }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer3", "other"],
      "properties": {
        "layer3": {
          "type": "array",
          "items": { "type": "string", "pattern": "^--ds-[a-z0-9-]+$" }
        },
        "other": { "type": "array", "items": { "type": "string", "pattern": "^--ds-[a-z0-9-]+$" } }
      }
    },
    "a11y": { "type": "array", "items": { "type": "string" } },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["do", "dont"],
      "properties": {
        "do": { "type": "array", "items": { "type": "string" } },
        "dont": { "type": "array", "items": { "type": "string" } }
      }
    },
    "boundaries": { "type": "array", "items": { "type": "string" } },
    "whenToUseInstead": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component", "when"],
        "properties": {
          "component": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "when": { "type": "string" }
        }
      }
    },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
