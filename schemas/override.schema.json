{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ziolkowskiw/kraken-ui-kit/schemas/override.schema.json",
  "title": "Kraken UI Kit manifest override (human judgment layer)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "$comment": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "keywords": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "do": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "dont": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "boundaries": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "whenToUseInstead": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component", "when"],
        "properties": {
          "component": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "when": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
