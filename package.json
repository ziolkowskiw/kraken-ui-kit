{
  "name": "kraken-ui-kit",
  "version": "0.0.1",
  "private": true,
  "description": "Kraken UI Kit \u2014 a shadcn-based design system with a 3-layer token architecture (global \u2192 semantic \u2192 component) and brand theming (jit / brand).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "tokens:build": "node scripts/build-tokens.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "registry:build": "node scripts/build-registry.mjs",
    "registry:bundle": "npm run registry:build && shadcn build",
    "docs:build": "node scripts/build-docs.mjs",
    "figma:binder": "node scripts/figma-binder.mjs",
    "figma:binder:validate": "node scripts/figma-binder.mjs --validate",
    "release": "node scripts/release.mjs",
    "release:minor": "node scripts/release.mjs --minor",
    "release:major": "node scripts/release.mjs --major"
  },
  "dependencies": {
